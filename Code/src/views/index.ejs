<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <title>Certificate Generator Dashboard</title>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body class="dashboard-page">
<div class="dashboard">
    <h1>Certificate Generator</h1>
    <p>Welcome to the administrative dashboard. Select a module below to get started.</p>

    <div class="button-grid">
        <% if (canAccessGenerator) { %>
            <a href="/certificates/generate" class="nav-btn">PDF Generation</a>
        <% } %>

        <% if (canAccessMaintenance) { %>
           <a href="/admin/maintenance" class="nav-btn">Maintenance</a>
        <% } %>

        <% if (canAccessUsers) { %>
            <a href="/admin/users" class="nav-btn">User Management</a>
        <% } %>

        <% if (canAccessTemplates) { %>
            <a href="/templates" class="nav-btn">Template Editor</a>
        <% } %>

        <% if (canAccessSettings) { %>
            <a href="/admin/settings" class="nav-btn" style="background-color: #6f42c1;">⚙ Assinatura Digital</a>
        <% } %>

        <a href="/auth/logout" class="nav-btn" style="background-color: #6c757d;">Logout</a>
    </div>
</div>
</body>

</html>