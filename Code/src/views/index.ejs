<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <title>Certificate Generator Dashboard</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            padding: 3rem 1rem;
            margin: 0;
        }

        .dashboard {
            max-width: 800px;
            width: 100%;
            background: white;
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        h1 { color: #333; margin-top: 0; }
        p { color: #666; margin-bottom: 2rem; }

        .button-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .nav-btn {
            padding: 1rem;
            background-color: #007bff;
            color: white;
            text-align: center;
            border-radius: 8px;
            font-weight: 600;
            transition: background 0.2s;
            text-decoration: none;
            display: block;
        }

        .nav-btn:hover {
            background-color: #0056b3;
        }

        .footer-note {
            margin-top: 3rem;
            font-size: 0.85rem;
            color: #999;
            border-top: 1px solid #eee;
            padding-top: 1rem;
        }
    </style>
</head>

<body>
<div class="dashboard">
    <h1>Certificate Generator</h1>
    <p>Welcome to the administrative dashboard. Select a module below to get started.</p>

    <div class="button-grid">
        <% if (canAccessGenerator) { %>
            <a href="/certificates/generate" class="nav-btn">PDF Generation</a>
        <% } %>

        <% if (canAccessMaintenance) { %>
           <a href="/admin/maintenance" class="nav-btn">Maintenance</a>
        <% } %>

        <% if (canAccessUsers) { %>
            <a href="/admin/users" class="nav-btn">User Management</a>
        <% } %>

        <% if (canAccessTemplates) { %>
            <a href="/templates" class="nav-btn">Template Editor</a>
        <% } %>
        <a href="/auth/logout" class="nav-btn" style="background-color: #6c757d;">Logout</a>
    </div>
</div>
</body>

</html>