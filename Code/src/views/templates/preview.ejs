<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Preview Template</title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .certificate-canvas {
            background-color: <%= layout.page.backgroundColor %>;
            border: <%= layout.page.borderWidth %>px solid <%= layout.page.borderColor %>;
        }
        .signature-box {
            border-top: 2px solid <%= layout.page.borderColor %>;
        }
    </style>
</head>
<body class="certificate-canvas-container">

<div class="certificate-canvas">
    <% elements.forEach(element => { %>
        <% if (element.isImage) { %>
            <div class="template-element image-element" style="<%= element.style %>">
                <img src="<%= element.content %>" style="width: 100%; height: 100%; object-fit: contain;" />
            </div>
        <% } else if (element.isSignature) { %>
            <div class="template-element signature-box" style="<%= element.style %>">
                <%= element.content %>
            </div>
        <% } else { %>
            <div class="template-element <%= element.isCentered ? 'template-element-centered' : '' %>" style="<%= element.style %>">
                <%= element.content %>
            </div>
        <% } %>
    <% }) %>
</div>

<script>
    function adjustScale() {
        const canvas = document.querySelector('.certificate-canvas');
        const containerWidth = window.innerWidth;
        const containerHeight = window.innerHeight;
        const canvasWidth = 1485;
        const canvasHeight = 1050;

        const scaleX = containerWidth / canvasWidth;
        const scaleY = containerHeight / canvasHeight;
        const scale = Math.min(scaleX, scaleY) * 0.95; // scale to fit with margin

        canvas.style.transform = `scale(${scale})`;
    }
    window.addEventListener('resize', adjustScale);
    window.addEventListener('load', adjustScale);
</script>

</body>
</html>
