<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Templates</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

<h1>Certificate Templates</h1>

<p><a href="/">Back to Dashboard</a></p>

<div class="actions" style="margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <form action="/templates" method="GET" class="form-inline">
        <input type="text" name="search" placeholder="Search by name or ID" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" style="min-width: 250px;">
        <button type="submit" class="primary-btn">Search</button>
        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
            <a href="/templates" style="margin-left: 10px;">Clear</a>
        <% } %>
    </form>

    <a href="/templates/create">
        <button class="success-btn">Create New Template</button>
    </a>
</div>

<% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
    <p>Showing results for: <strong><%= searchQuery %></strong></p>
<% } %>

<% if (templates && templates.length > 0) { %>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

    <% templates.forEach(template => { %>
        <% const matchedCourse = (courses || []).find(c => c.id === template.courseId); %>
        <tr>
            <td><%= template.id %></td>
            <td><%= template.name %></td>
            <td><%= matchedCourse ? matchedCourse.name : (template.courseId || 'None') %></td>

            <td>

                <a href="/templates/edit/<%= template.id %>">
                    <button type="button" class="primary-btn">Edit</button>
                </a>

                <form
                    action="/templates/delete"
                    method="POST"
                    style="display:inline;"
                >
                    <input
                        type="hidden"
                        name="id"
                        value="<%= template.id %>"
                    >

                    <button
                        type="submit"
                        class="danger-btn"
                        onclick="return confirm('Delete this template?')"
                    >
                        Delete
                    </button>
                </form>

            </td>
        </tr>

    <% }) %>

    </tbody>
</table>

<% } else { %>

<p>No templates found.</p>

<% } %>

</body>
</html>