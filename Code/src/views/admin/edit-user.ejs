<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User – Admin</title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .form-panel {
            max-width: 520px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            margin-bottom: 1.1rem;
        }
        .form-group label {
            font-weight: 600;
            margin-bottom: 0.35rem;
            color: #333;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            box-sizing: border-box;
        }
        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 1.5rem;
            align-items: center;
        }
        .hint {
            font-size: 12px;
            color: #888;
            margin-top: 3px;
        }
        .user-id-badge {
            display: inline-block;
            background: #e9ecef;
            color: #495057;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 13px;
            margin-bottom: 1.25rem;
            font-weight: 600;
        }
    </style>
</head>
<body>

<h1>Edit User</h1>

<span class="user-id-badge">ID: <%= user.id %></span>

<% if (errorMessage) { %>
    <p class="error"><%= errorMessage %></p>
<% } %>

<div class="card form-panel">
    <form action="/admin/users/edit/<%= user.id %>" method="POST" id="form-edit-user">

        <div class="form-group">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" required
                   value="<%= firstName %>" maxlength="100" placeholder="Ex: João">
        </div>

        <div class="form-group">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" required
                   value="<%= lastName %>" maxlength="100" placeholder="Ex: Silva">
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required
                   value="<%= user.email %>" maxlength="255" placeholder="user@example.com">
        </div>

        <div class="form-group">
            <label for="password">New Password <span style="font-weight:400;color:#888;">(optional)</span></label>
            <input type="password" id="password" name="password" minlength="6"
                   placeholder="Leave blank to keep current password.">
            <span class="hint">Only fill if you wanna change the password..</span>
        </div>

        <div class="form-group">
            <label for="role">Role</label>
            <select id="role" name="role" required>
                <option value="USER"  <%= user.role === 'USER'  ? 'selected' : '' %>>USER</option>
                <option value="ADMIN" <%= user.role === 'ADMIN' ? 'selected' : '' %>>ADMIN</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-btn" id="btn-submit-edit">Save Changes</button>
            <a href="/admin/users" class="back-link" style="margin:0;">Cancel</a>
        </div>

    </form>
</div>

<p style="margin-top:1rem;"><a href="/admin/users" class="back-link">← Back to List</a></p>

</body>
</html>
