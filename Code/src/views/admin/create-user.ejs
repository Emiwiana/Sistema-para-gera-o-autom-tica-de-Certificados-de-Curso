<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create User – Admin</title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .form-panel {
            max-width: 520px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            margin-bottom: 1.1rem;
        }
        .form-group label {
            font-weight: 600;
            margin-bottom: 0.35rem;
            color: #333;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            box-sizing: border-box;
        }
        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 1.5rem;
            align-items: center;
        }
        .hint {
            font-size: 12px;
            color: #888;
            margin-top: 3px;
        }
    </style>
</head>
<body>

<h1>Create User</h1>

<% if (errorMessage) { %>
    <p class="error"><%= errorMessage %></p>
<% } %>

<div class="card form-panel">
    <form action="/admin/users/create" method="POST" id="form-create-user">

        <div class="form-group">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" required placeholder="Ex: João" maxlength="100">
        </div>

        <div class="form-group">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" required placeholder="Ex: Silva" maxlength="100">
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="user@example.com" maxlength="255">
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required minlength="6" placeholder="Minimum 6 characters">
            <span class="hint">The password will be securely stored (bcrypt).</span>
        </div>

        <div class="form-group">
            <label for="role">Role</label>
            <select id="role" name="role" required>
                <option value="">-- Select Role --</option>
                <option value="USER">USER</option>
                <option value="ADMIN">ADMIN</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="success-btn" id="btn-submit-create">Create User</button>
            <a href="/admin/users" class="back-link" style="margin:0;">Cancel</a>
        </div>

    </form>
</div>

<p style="margin-top:1rem;"><a href="/admin/users" class="back-link">← Back to List</a></p>

</body>
</html>
