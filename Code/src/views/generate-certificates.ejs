<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>PDF Generation Test</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 2rem; line-height: 1.5; }
        .card { max-width: 760px; padding: 1.5rem; border: 1px solid #ccc; border-radius: 10px; }
    </style>
</head>
<body>
<div class="card">
    <h1>PDF Generation Test</h1>
    <p>5 sample PDFs were generated in one batch.</p>
    <ul>
        <% generatedFiles.forEach(function(file) { %>
            <li>
                <%= file.fileName %> —
                <% if (file.exists) { %>
                    <a href="<%= file.url %>">Open PDF</a>
                <% } else { %>
                    not generated
                <% } %>
            </li>
        <% }); %>
    </ul>
    <p><a href="/">Back to homepage</a></p>
</div>
</body>
</html>