<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Generate Certificates</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<div class="card">
    <h1>Generate Certificates</h1>
    <p><a href="/">Back to Dashboard</a></p>

    <% if (successMessage) { %> <div class="success"><%= successMessage %></div> <% } %>
    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %> <div class="error"><%= errorMessage %></div> <% } %>

    <div class="filter-bar">
        <form action="/certificates/generate" method="GET">
            <label>Course:</label>
            <select name="courseId">
                <option value="">All Courses</option>
                <% courses.forEach(course => { %>
                    <option value="<%= course.id %>" <%= filters.courseId === course.id ? 'selected' : '' %>>
                        <%= course.name %>
                    </option>
                <% }) %>
            </select>

            <label>Year:</label>
            <input type="number" name="year" placeholder="e.g., 2024" value="<%= filters.year || '' %>">

            <button type="submit">Apply Filters</button>
            <a href="/certificates/generate">Clear All</a>
        </form>

        <% if (filters.courseId || filters.year) { %>
        <div class="active-filters">
            <span style="font-weight: 600;">Active Filters:</span>
            <% if (filters.courseId) { 
                const courseName = courses.find(c => c.id === filters.courseId)?.name || filters.courseId;
            %>
                <a href="?year=<%= filters.year || '' %>" class="filter-chip">Course: <%= courseName %> &times;</a>
            <% } %>
            <% if (filters.year) { %>
                <a href="?courseId=<%= filters.courseId || '' %>" class="filter-chip">Year: <%= filters.year %> &times;</a>
            <% } %>
        </div>
        <% } %>
    </div>

    <form method="POST">
        <div style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
            <label style="font-weight: 600;">Select Template (For Generation):</label>
            <select name="templateId" style="min-width: 250px;">
                <option value="">-- Choose a template --</option>
                <% templates.forEach(tpl => { %>
                    <option value="<%= tpl.id %>"><%= tpl.name %> (ID: <%= tpl.id %>)</option>
                <% }) %>
            </select>
            <% if (templates.length === 0) { %>
                <span style="color: red; font-size: 0.9rem; font-weight: bold;">
                    No templates found. Please <a href="/templates/create" style="text-decoration: underline; color: red;">Create a template first</a>.
                </span>
            <% } %>
        </div>

        <table>
            <thead>
            <tr>
                <th><input type="checkbox" id="selectAll" title="Select all filtered students"></th>
                <th>Student Name</th>
                <th>Email</th>
                <th>Course</th>
                <th>Status</th>
            </tr>
            </thead>
            <tbody>
            <% if (students.length === 0) { %>
                <tr><td colspan="5">No eligible students found.</td></tr>
            <% } %>

            <% students.forEach(student => { %>
                <tr>
                    <td><input type="checkbox" name="studentIds" value="<%= student.id %>" class="student-checkbox" data-has-pdf="<%= student.hasPdf %>"></td>
                    <td><%= student.name %></td>
                    <td><%= student.email %></td>
                    <td><%= student.course.name %></td>
                    <td>
                        <% if (student.hasPdf) { %>
                            <span class="badge success-badge">✅ PDF Ready</span>
                        <% } else { %>
                            <span class="badge secondary-badge">⚪ Not Generated</span>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
            </tbody>
        </table>

        <% if (students.length > 0) { %>
            <div class="action-buttons">
                <button type="submit" class="success-btn" formaction="/certificates/generate" id="generateBtn">
                    Generate Selected Certificates
                </button>
                <button type="submit" class="primary-btn" formaction="/certificates/email" id="emailBtn">
                    ✉️ Email Selected Students
                </button>
            </div>
        <% } %>
    </form>
</div>
<script>
    (function(){
        const selectAll = document.getElementById('selectAll');
        if (!selectAll) return;
        selectAll.addEventListener('change', (e) => {
            const checked = e.target.checked;
            document.querySelectorAll('.student-checkbox').forEach(cb => cb.checked = checked);
        });
    })();
</script>
</body>
</html>